<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VGCダメージ計算機</title>
    <style>
        body { font-family: sans-serif; background-color: #f0f4f8; padding: 10px; font-size: 14px; }
        .container { max-width: 100%; background: white; padding: 15px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        .grid { display: block; } /* モバイルで見やすいよう縦並びに */
        .box { border: 1px solid #ddd; padding: 10px; border-radius: 8px; margin-bottom: 10px; }
        h3 { margin-top: 0; font-size: 1rem; color: #2b6cb0; }
        .input-group { margin-bottom: 8px; }
        label { display: block; font-size: 12px; font-weight: bold; }
        input, select { width: 100%; padding: 6px; box-sizing: border-box; border: 1px solid #ccc; border-radius: 4px; }
        .checkbox-group { display: flex; flex-wrap: wrap; gap: 5px; background: #fffaf0; padding: 5px; border-radius: 4px; }
        .checkbox-item { font-size: 12px; display: flex; align-items: center; }
        button { width: 100%; padding: 15px; background: #3182ce; color: white; border: none; border-radius: 8px; font-weight: bold; margin-top: 10px; }
        #result { margin-top: 15px; padding: 15px; background: #2d3748; color: #e2e8f0; border-radius: 8px; white-space: pre-wrap; min-height: 50px; }
    </style>
</head>
<body>

<div class="container">
    <h2>VGCダメージ計算機</h2>
    
    <div class="box">
        <h3>攻撃側</h3>
        <div class="input-group"><label>自分のタイプ</label><select id="atkType" class="type-select"></select></div>
        <div class="input-group"><label>攻撃実数値</label><input type="number" id="atkStat" value="200"></div>
        <div class="input-group"><label>ランク</label>
            <select id="atkBoost"><option value="2">+2</option><option value="1">+1</option><option value="0" selected>0</option><option value="-1">-1</option></select>
        </div>
        <div class="input-group"><label>技威力 / 技タイプ</label>
            <div style="display: flex; gap: 5px;"><input type="number" id="movePower" value="80"><select id="moveType" class="type-select"></select></div>
        </div>
        <div class="checkbox-group">
            <label class="checkbox-item"><input type="checkbox" id="isStab" checked> 一致</label>
            <label class="checkbox-item"><input type="checkbox" id="isHelpingHand"> てだすけ</label>
        </div>
    </div>

    <div class="box">
        <h3>防御側 / フィールド</h3>
        <div class="input-group"><label>HP実数値</label><input type="number" id="hpStat" value="175"></div>
        <div class="input-group"><label>防御実数値</label><input type="number" id="defStat" value="120"></div>
        <div class="input-group"><label>相性倍率</label>
            <select id="typeMod"><option value="4">4倍</option><option value="2" selected>2倍</option><option value="1">1倍</option><option value="0.5">0.5倍</option></select>
        </div>
        <div class="checkbox-group">
            <label class="checkbox-item"><input type="checkbox" id="isReflect"> 壁</label>
            <label class="checkbox-item"><input type="checkbox" id="isTaru"> チョッキ</label>
        </div>
    </div>

    <button id="calcBtn">ダメージ計算実行</button>
    <div id="result">ここに結果が表示されます</div>
</div>

<script src="https://unpkg.com/@smogon/calc/dist/index.min.js"></script>

<script>
    // タイプデータ
    const types = [
        {en: "Normal", jp: "ノーマル"}, {en: "Fire", jp: "ほのお"}, {en: "Water", jp: "みず"},
        {en: "Grass", jp: "くさ"}, {en: "Electric", jp: "でんき"}, {en: "Ice", jp: "こおり"},
        {en: "Fighting", jp: "かくとう"}, {en: "Poison", jp: "どく"}, {en: "Ground", jp: "じめん"},
        {en: "Flying", jp: "ひこう"}, {en: "Psychic", jp: "エスパー"}, {en: "Bug", jp: "むし"},
        {en: "Rock", jp: "いわ"}, {en: "Ghost", jp: "ゴースト"}, {en: "Dragon", jp: "ドラゴン"},
        {en: "Dark", jp: "あく"}, {en: "Steel", jp: "はがね"}, {en: "Fairy", jp: "フェアリー"}
    ];

    // 初期化処理
    window.addEventListener('DOMContentLoaded', function() {
        // タイプ選択肢の生成
        const selects = document.querySelectorAll('.type-select');
        selects.forEach(select => {
            types.forEach(t => {
                const opt = document.createElement('option');
                opt.value = t.en;
                opt.textContent = t.jp;
                if (t.en === 'Water') opt.selected = true;
                select.appendChild(opt);
            });
        });

        // ボタンクリックイベントの登録
        document.getElementById('calcBtn').addEventListener('click', runCalc);
    });

    function runCalc() {
        // ライブラリが読み込まれているか確認
        if (typeof smogon === 'undefined' || !smogon.calc) {
            alert("ライブラリを読み込み中です。数秒待ってから再度お試しください。");
            return;
        }

        try {
            const { calculate, Pokemon, Move, Field } = smogon.calc;
            const gen = 9;

            const moveType = document.getElementById('moveType').value;
            const atkType = document.getElementById('atkType').value;

            const attacker = new Pokemon(gen, 'Ditto', {
                level: 50,
                types: [document.getElementById('isStab').checked ? moveType : 'Normal'],
                boosts: { atk: parseInt(document.getElementById('atkBoost').value), spa: parseInt(document.getElementById('atkBoost').value) },
                rawStats: { atk: parseInt(document.getElementById('atkStat').value), spa: parseInt(document.getElementById('atkStat').value) }
            });

            const defender = new Pokemon(gen, 'Ditto', {
                level: 50,
                item: document.getElementById('isTaru').checked ? 'Assault Vest' : '',
                rawStats: { 
                    hp: parseInt(document.getElementById('hpStat').value),
                    def: parseInt(document.getElementById('defStat').value),
                    spd: parseInt(document.getElementById('defStat').value)
                }
            });

            const move = new Move(gen, 'Tackle', { 
                basePower: parseInt(document.getElementById('movePower').value),
                type: moveType
            });

            const field = new Field({ 
                gameType: 'Doubles',
                isHelpingHand: document.getElementById('isHelpingHand').checked,
                isReflect: document.getElementById('isReflect').checked,
                isLightScreen: document.getElementById('isReflect').checked
            });

            const result = calculate(gen, attacker, defender, move, field);
            const typeMod = parseFloat(document.getElementById('typeMod').value);
            const damage = result.damage.map(d => Math.floor(d * typeMod));
            
            const minD = damage[0];
            const maxD = damage[damage.length - 1];
            const hp = defender.rawStats.hp;

            document.getElementById('result').innerHTML = 
                `【計算結果】\n` +
                `ダメージ: ${minD} ～ ${maxD}\n` +
                `割合: ${((minD/hp)*100).toFixed(1)}% ～ ${((maxD/hp)*100).toFixed(1)}%\n` +
                `判定: ${minD >= hp ? '確定1発' : '確定' + Math.ceil(hp/maxD) + '発'}`;
        } catch (e) {
            document.getElementById('result').innerText = "エラーが発生しました: " + e.message;
        }
    }
</script>
</body>
</html>
